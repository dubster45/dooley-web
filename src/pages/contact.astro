---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact | Dooley Technology Solutions"
  description="Contact Dooley Technology Solutions for cloud, DevOps, and infrastructure consulting."
>
  <section class="page-header">
    <div class="container">
      <div class="eyebrow">Contact</div>
      <h1>Let’s talk about your infrastructure goals.</h1>
      <p>
        Use the form below to describe what you need help with. This can be connected
        to Formspree, Basin, or an AWS-native backend later.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <form class="form" method="POST" action="#">
        <label>
          Name
          <input type="text" name="name" placeholder="Your name" required />
        </label>

        <label>
          Company
          <input type="text" name="company" placeholder="Company name" />
        </label>

        <label>
          Email
          <input type="email" name="email" placeholder="you@example.com" required />
        </label>

        <label>
          What do you need help with?
          <textarea
            name="message"
            placeholder="Tell us about your cloud, DevOps, infrastructure, or AI-readiness needs."
            required
          ></textarea>
        </label>

        <button class="button" type="submit">Send Message</button>
      </form>
    </div>
  </section>
</BaseLayout>