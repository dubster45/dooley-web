---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About | Dooley Technology Solutions"
  description="About Dooley Technology Solutions, a cloud, DevOps, and infrastructure consulting company."
>
  <section class="page-header">
    <div class="container">
      <div class="eyebrow">About</div>
      <h1>Experienced infrastructure support for teams that need systems to work.</h1>
      <p>
        Dooley Technology Solutions helps businesses design, automate, secure,
        and troubleshoot the cloud and DevOps systems that modern applications depend on.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container grid two">
      <div>
        <h2>Focused on practical results.</h2>
        <p>
          The company is built around hands-on infrastructure experience across cloud
          platforms, Linux systems, automation, containers, monitoring, and production
          troubleshooting.
        </p>

        <p>
          The goal is simple: help teams reduce infrastructure confusion, improve
          reliability, automate repeatable work, and make better technical decisions.
        </p>
      </div>

      <div class="card">
        <h3>Core areas</h3>
        <p>
          AWS, Linux, Terraform, Kubernetes, Docker, SaltStack, Jenkins, Datadog,
          networking, load balancing, TLS, monitoring, and cloud modernization.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>