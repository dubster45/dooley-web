---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Services | Dooley Technology Solutions"
  description="Cloud infrastructure, DevOps automation, Kubernetes, monitoring, and AI infrastructure readiness services."
>
  <section class="page-header">
    <div class="container">
      <div class="eyebrow">Services</div>
      <h1>Infrastructure services built around reliability, automation, and clarity.</h1>
      <p>
        We help teams improve cloud environments, automate delivery, troubleshoot
        production issues, and prepare systems for modern AI-enabled workflows.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container grid two">
      <div class="card">
        <h3>Cloud Infrastructure</h3>
        <p>
          AWS environment design, VPCs, subnets, routing, security groups, IAM,
          Route 53, EC2, load balancers, VPNs, storage, and cloud modernization.
        </p>
      </div>

      <div class="card">
        <h3>DevOps Automation</h3>
        <p>
          Terraform, Jenkins, SaltStack, Git workflows, Linux automation, deployment
          scripting, and repeatable infrastructure patterns.
        </p>
      </div>

      <div class="card">
        <h3>Kubernetes & Containers</h3>
        <p>
          Docker deployments, Kubernetes/EKS support, container troubleshooting,
          ingress/load balancing, service exposure, and platform reliability.
        </p>
      </div>

      <div class="card">
        <h3>Monitoring & Reliability</h3>
        <p>
          Datadog, logging, alerting, dashboards, performance review, uptime analysis,
          incident response support, and operational visibility.
        </p>
      </div>

      <div class="card">
        <h3>Migration & Troubleshooting</h3>
        <p>
          On-prem to cloud support, hybrid networking, TLS/certificate issues,
          application connectivity, Linux systems, Kafka, NiFi, and database platforms.
        </p>
      </div>

      <div class="card">
        <h3>AI Infrastructure Readiness</h3>
        <p>
          Infrastructure planning for AI tools, automation platforms, secure APIs,
          data pipelines, cloud access patterns, and operational support models.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>